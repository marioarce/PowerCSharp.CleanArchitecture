<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <!--
      Local folder feed (repo-relative, git-ignored) used to consume PowerCSharp Features packages
      during template development. Regenerate it with: scripts/pack-local-feed.sh [path-to-PowerCSharp]
    -->
    <add key="powercsharp-local" value="local-feed" />
  </packageSources>
</configuration>

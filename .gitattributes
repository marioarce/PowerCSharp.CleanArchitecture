# Normalize line endings: treat everything as text and check out with LF.
* text=auto eol=lf

# Source and config files (LF)
*.cs        text eol=lf diff=csharp
*.csproj    text eol=lf
*.sln       text eol=crlf
*.props     text eol=lf
*.targets   text eol=lf
*.config    text eol=lf
*.json      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.md        text eol=lf
*.editorconfig text eol=lf
*.sh        text eol=lf

# Windows-specific scripts (CRLF)
*.cmd       text eol=crlf
*.bat       text eol=crlf
*.ps1       text eol=crlf

# Binary files (never normalize)
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.snk       binary
*.pfx       binary
*.dll       binary
*.exe       binary
*.nupkg     binary

{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "PowerFeatures": {
    "Cors": {
      "Enabled": true,
      "PolicyName": "DefaultCors",
      "AllowedOrigins": [ "https://localhost" ]
    },
    "Cache": {
      "Enabled": true,
      "Provider": "BitFaster",
      "Capacity": 1000,
      "Disk": {
        "DirectoryPath": "./cache",
        "MaxEntries": 10000,
        "DefaultTtlSeconds": 3600,
        "EnableBackgroundCleanup": true,
        "CleanupIntervalSeconds": 300,
        "EnableCrossProcessLocking": false
      }
    },
    "DiskCache": {
      "Enabled": true
    },
    "Samples": {
      "Enabled": false
    }
  }
}
